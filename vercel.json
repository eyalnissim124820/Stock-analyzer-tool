{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/analyze.js": { "maxDuration": 10 },
    "api/strategy.js": { "maxDuration": 15 },
    "api/tracker.js": { "maxDuration": 10 },
    "api/chart.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/hebrew", "destination": "/hebrew.html" }
  ]
}
